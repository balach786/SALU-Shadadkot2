# =============================================================
#  SALU SMART ADMISSION SYSTEM – Environment Variables
# =============================================================
#  Copy this file to `.env` (or `.env.local`) and fill in the
#  real values. NEVER commit your actual .env file to git.
# =============================================================


# -------------------------------------------------------------
# 🔐 SERVER-SIDE SECRETS  (server functions only – never exposed to browser)
# -------------------------------------------------------------

# Password used to log in to the /admin panel.
# Set this to a strong, private password of your choice.
# Source: Choose your own secure password.
ADMIN_PASSWORD=change_me_to_a_strong_password

# Secret key used to encrypt the admin session cookie.
# Must be at least 32 characters long.
# Source: Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_me_to_a_random_32plus_char_secret_key_here


# -------------------------------------------------------------
# 🌐 CLIENT-SIDE CONFIG  (visible in the browser)
# -------------------------------------------------------------

# Your deployed Google Apps Script Web App URL (must end with /exec).
# This powers form submissions, CNIC search, and admin data listing.
#
# How to get this URL:
#   1. Open https://script.google.com and create a new project.
#   2. Paste the contents of docs/apps-script.gs from this repo.
#   3. Set SHEET_ID and DRIVE_FOLDER_ID at the top of that file.
#   4. Click Deploy → New deployment → Type: Web app
#        - Execute as: Me
#        - Who has access: Anyone
#   5. Copy the generated /exec URL and paste it here.
#
# Until this is set, form submission and CNIC search will show
# a "Backend not configured" message.
#
# NOTE: In code this is currently hardcoded in src/lib/config.ts.
# Move it here and read it via import.meta.env.VITE_APPS_SCRIPT_URL
# to keep secrets out of source control.
VITE_APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycbxvZ4IG0dK7hDgvkooECp9eAdNaRonnNoSEDgqeSDMXsTY42tVyZC-QMqIAR_9FzyUE/exec

# The public base URL of your deployed site (used for the sitemap).
# Example for production: https://salu-shadadkot.edu.pk
# Example for local dev:  http://localhost:3000
#
# NOTE: In code this is currently hardcoded in src/routes/sitemap[.]xml.ts.
# Move it here and read it via import.meta.env.VITE_BASE_URL.
VITE_BASE_URL=https://salu-shadadkot.edu.pk
